Screen {
    background: $surface;
}

#body {
    height: 1fr;
}

.section-title {
    color: $accent;
    text-style: bold;
    padding: 1 1 0 1;
}

.status {
    color: $text-muted;
    padding: 0 1 1 1;
}

.sidebar {
    width: 28;
    background: $boost;
    border-right: solid $accent;
    padding: 1;
}

.main-pane {
    width: 1fr;
    padding: 1 2;
}

Button {
    width: 100%;
    margin: 0 0 1 0;
}

DataTable {
    height: 1fr;
    margin-top: 1;
}
